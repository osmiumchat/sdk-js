{
  "name": "@osmiumchat/sdk",
  "version": "0.1.0",
  "description": "Official JavaScript SDK for Osmium Chat",
  "repository": {
    "type": "git",
    "url": "https://github.com/osmiumchat/sdk-js",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@osmiumchat/proto": "workspace:*",
    "@vladfrangu/async_event_emitter": "^2.4.7",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
